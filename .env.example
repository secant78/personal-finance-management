# Vaultwarden connection — entered via the setup UI and saved to bootstrap.json.
# These are only needed if you want to pre-populate the environment instead.
# VAULTWARDEN_URL=https://vault.example.com
# BW_CLIENTID=user.xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# BW_CLIENTSECRET=your_client_secret
# BW_PASSWORD=your_master_password
